# Byline Environment Configuration Template
# Copy this file to .env in each component and fill in values

# === STELLAR NETWORK ===
# Use 'https://soroban-testnet.stellar.org' for development
# Use 'https://soroban-mainnet.stellar.org' for production
STELLAR_RPC_URL=https://soroban-testnet.stellar.org

# Contract ID deployed on Stellar
# Get this after deploying the contract
STELLAR_CONTRACT_ID=your_contract_id_here

# === READER APP ===
# Backend API URL
VITE_API_URL=http://localhost:3000

# Stellar network passphrase (testnet or public)
VITE_STELLAR_NETWORK=Test SDF Network ; September 2015

# === PUBLISHER BACKEND ===
# Server port
PORT=3000

# Node environment
NODE_ENV=development

# Log level (debug, info, warn, error)
LOG_LEVEL=info

# Token verification settings
TOKEN_EXPIRY_HOURS=24
TOKEN_CACHE_TTL_MINUTES=5

# Analytics settings
ANALYTICS_RETENTION_DAYS=30

# === PUBLISHER SDK ===
# Backend verification endpoint
PUBLISHER_API_URL=http://localhost:3000

# Publisher ID (obtained during onboarding)
PUBLISHER_ID=your_publisher_id

# Publisher secret key for signing requests
PUBLISHER_SECRET=your_secret_key

# === SECURITY ===
# HTTPS only in production
HTTPS_ONLY=false

# CORS settings
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# === DATABASE (Future) ===
# DATABASE_URL=postgresql://user:password@localhost:5432/byline
# DATABASE_POOL_SIZE=20

# === MONITORING ===
# Sentry error tracking
SENTRY_DSN=

# New Relic
NEW_RELIC_LICENSE_KEY=
